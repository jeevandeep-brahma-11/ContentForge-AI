# LLM provider — "gemini" or "anthropic". The provider whose key is set below
# will be registered on startup. Set LLM_PROVIDER to the one you want as default.
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash

GEMINI_API_KEY=
ANTHROPIC_API_KEY=
# Optional — only needed if you register additional providers:
OPENAI_API_KEY=

# Web research
FIRECRAWL_API_KEY=

# Storage
DATABASE_URL=sqlite+aiosqlite:///./contentforge.db

# Background trends worker
TRENDS_REFRESH_MINUTES=60
TRENDS_NICHES=ai tools,productivity,finance,tech reviews

# Pipeline
MAX_FEEDBACK_LOOPS=2
